{
  "name": "local-pos-software",
  "version": "0.1.0",
  "private": true,
  "description": "Sistema POS modular, multiplataforma y offline-first para comercios minoristas",
  "main": ".dist/electron/main.js",
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  },
  "scripts": {
    "dev": "concurrently -k -n server,renderer,electron \"npm run dev:server\" \"npm run dev:renderer\" \"npm run dev:electron\"",
    "dev:server": "tsx watch server/server.ts",
    "dev:renderer": "vite",
    "dev:electron": "wait-on tcp:5173 && tsc -p tsconfig.node.json --outDir .dist && electron .dist/electron/main.js",
    "build": "tsc -p tsconfig.node.json --outDir dist && vite build",
    "typecheck": "tsc --noEmit && tsc --noEmit -p tsconfig.node.json",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext ts,tsx --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx server/db/migrate.ts",
    "db:studio": "drizzle-kit studio",
    "db:seed": "tsx server/db/seed.ts",
    "db:reset": "tsx server/db/reset.ts",
    "rebuild": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-rebuild -f -w better-sqlite3",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "dist:linux": "npm run build && electron-builder --linux"
  },
  "dependencies": {
    "@afipsdk/afip.js": "^1.2.3",
    "@supabase/supabase-js": "^2.39.0",
    "bcryptjs": "^3.0.3",
    "better-sqlite3": "^12.9.0",
    "cors": "^2.8.5",
    "date-fns": "^3.0.0",
    "drizzle-orm": "^0.29.0",
    "electron-store": "^8.1.0",
    "electron-updater": "^6.1.0",
    "express": "^4.19.0",
    "lucide-react": "^0.383.0",
    "nanoid": "^5.0.4",
    "node-cron": "^3.0.3",
    "node-thermal-printer": "^4.4.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.50.0",
    "tailwindcss": "^3.4.0",
    "zod": "^3.22.0",
    "zustand": "^4.5.0"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.4",
    "@testing-library/react": "^14.1.2",
    "@types/bcryptjs": "^2.4.6",
    "@types/better-sqlite3": "^7.6.8",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^20.11.0",
    "@types/react": "^18.2.55",
    "@types/react-dom": "^18.2.19",
    "@typescript-eslint/eslint-plugin": "^6.21.0",
    "@typescript-eslint/parser": "^6.21.0",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.17",
    "concurrently": "^8.2.0",
    "drizzle-kit": "^0.20.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "eslint": "^8.56.0",
    "eslint-plugin-react": "^7.33.2",
    "eslint-plugin-react-hooks": "^4.6.0",
    "jsdom": "^29.0.2",
    "playwright": "^1.41.0",
    "postcss": "^8.4.35",
    "prettier": "^3.2.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vite": "^5.0.0",
    "vitest": "^1.2.0",
    "wait-on": "^7.2.0"
  },
  "build": {
    "appId": "com.localpos.app",
    "productName": "LocalPosSoftware",
    "directories": {
      "output": "dist-electron"
    },
    "files": [
      "dist/**/*",
      ".dist/**/*"
    ],
    "win": {
      "target": "nsis"
    },
    "mac": {
      "target": "dmg"
    },
    "linux": {
      "target": "AppImage"
    }
  }
}

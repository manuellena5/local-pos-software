# ── Supabase (opcional) ──────────────────────────────────────────────────────
# Si no están configuradas, el sync con Supabase queda deshabilitado.
# La app funciona 100% offline sin estas variables.
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Intervalo de sync automático (minutos). Default: 5
SYNC_INTERVAL_MINUTES=5

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=3001

# ── AFIP ──────────────────────────────────────────────────────────────────────
# "mock" (default): genera un CAE falso, no llama a AFIP.
# "disabled": no intenta facturar nada — la venta queda como ticket interno.
# "testing" | "production": requieren AFIP_CUIT, AFIP_CERT_PATH, AFIP_KEY_PATH reales.
AFIP_ENVIRONMENT=mock

# ── Seed de datos de prueba ───────────────────────────────────────────────────
# Si es "true", carga/actualiza el catálogo desde resources/seed/productos.csv
# en cada arranque (idempotente). Ver resources/seed/README.md.
SEED_DEMO=false

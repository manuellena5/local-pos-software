# ── Supabase (opcional) ──────────────────────────────────────────────────────
# Si no están configuradas, el sync con Supabase queda deshabilitado.
# La app funciona 100% offline sin estas variables.
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Intervalo de sync automático (minutos). Default: 5
SYNC_INTERVAL_MINUTES=5

# ── Server ────────────────────────────────────────────────────────────────────
SERVER_PORT=3001

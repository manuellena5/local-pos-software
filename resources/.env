# Configuración de esta versión de prueba de Espacio BIP.
# Podés editar este archivo directamente en la carpeta de instalación
# (junto al .exe, en resources/.env) sin recompilar la app — reiniciá
# la app después de guardar los cambios.

# AFIP desactivada: las ventas se registran como ticket interno, sin
# factura electrónica. Para activarla en el futuro, cambiar a "mock"
# (CAE falso, para seguir probando) o "testing"/"production" (real).
AFIP_ENVIRONMENT=disabled

# Carga el catálogo de prueba desde seed/productos.csv en cada arranque
# (idempotente, no duplica). Poné "false" para arrancar sin datos de prueba.
SEED_DEMO=true

# ── Supabase (opcional) ──────────────────────────────────────────────────
# Completá con un proyecto de TEST si querés probar la sincronización a la
# nube. Si se dejan vacíos, la app funciona 100% offline sin sync.
SUPABASE_URL=
SUPABASE_ANON_KEY=
